# Email server API base URL
M3_EMAIL_SERVER_API_URL=http://127.0.0.1:5002

# AISuite provider keys (use Google Gemini here)
GOOGLE_API_KEY=your_google_api_key_here

# Optional proxy settings
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# OpenAI API Configuration
# 从 https://platform.openai.com/api-keys 获取你的 API 密钥
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Other AI Providers (如果使用 AISuite 的多模型支持)
# ANTHROPIC_API_KEY=your_anthropic_key
# GOOGLE_API_KEY=your_google_key

# Google Gemini API配置 (Vertex AI)


# 代理配置（如果需要）
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897
